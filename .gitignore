# Python caches and local environments
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.env
*.env

# Real datasets and downloaded archives are regenerated by scripts.
/datasets/*

# Trained checkpoints, generated demos, and metric outputs are regenerated by scripts.
/outputs/*

# Reports are kept locally for coursework submission and are not uploaded to the code repository.
/reports/

# Large local tool/runtime dependencies and generated helper assets
/tools/tectonic/
/artifacts/

# Archives and model binaries should not be committed to the source repository.
*.zip
*.pptx
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.npy
*.npz

# LaTeX build byproducts
/main.pdf
/reports/**/main.pdf
*.aux
*.log
*.out
*.toc
*.xdv
*.synctex.gz

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
